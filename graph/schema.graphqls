# Magento 2 Customer GraphQL Schema
# Go drop-in replacement for Magento's customer-related GraphQL queries and mutations

type Query {
    """Returns information about the logged-in customer. Requires Authorization header."""
    customer: Customer

    """Check whether the specified email has already been used to create a customer account."""
    isEmailAvailable(email: String!): IsEmailAvailableOutput

    """Returns the customer group of the logged-in customer."""
    customerGroup: CustomerGroup!
}

type Mutation {
    """Generate a token for a registered customer."""
    generateCustomerToken(email: String!, password: String!): CustomerToken

    """Revoke the customer token."""
    revokeCustomerToken: RevokeCustomerTokenOutput

    """Create a new customer account."""
    createCustomerV2(input: CustomerCreateInput!): CustomerOutput

    """Update the logged-in customer. Requires Authorization header."""
    updateCustomerV2(input: CustomerUpdateInput!): CustomerOutput

    """Change the password for the logged-in customer."""
    changeCustomerPassword(currentPassword: String!, newPassword: String!): Customer

    """Update the customer's email address. Requires current password for verification."""
    updateCustomerEmail(email: String!, password: String!): CustomerOutput

    """Create a new customer address."""
    createCustomerAddress(input: CustomerAddressInput!): CustomerAddress

    """Update an existing customer address by ID."""
    updateCustomerAddress(id: Int!, input: CustomerAddressInput!): CustomerAddress

    """Delete a customer address by ID."""
    deleteCustomerAddress(id: Int!): Boolean

    """Update an existing customer address by UID."""
    updateCustomerAddressV2(uid: ID!, input: CustomerAddressInput!): CustomerAddress

    """Delete a customer address by UID."""
    deleteCustomerAddressV2(uid: ID!): Boolean

    """Delete the logged-in customer account."""
    deleteCustomer: Boolean

    """Request a password reset email for the specified email address."""
    requestPasswordResetEmail(email: String!): Boolean

    """Reset customer password using a reset token."""
    resetPassword(email: String!, resetPasswordToken: String!, newPassword: String!): Boolean

    """Confirm a customer email address using a confirmation key."""
    confirmEmail(input: ConfirmEmailInput!): CustomerOutput

    """Resend the confirmation email for the specified email address."""
    resendConfirmationEmail(email: String!): Boolean

    """Create a new customer account (deprecated)."""
    createCustomer(input: CustomerInput!): CustomerOutput @deprecated(reason: "Use 'createCustomerV2' instead.")

    """Update the logged-in customer (deprecated)."""
    updateCustomer(input: CustomerInput!): CustomerOutput @deprecated(reason: "Use 'updateCustomerV2' instead.")
}

# ─── Output Types ────────────────────────────────────────────────────────────

type Customer {
    id: ID!
    firstname: String
    lastname: String
    middlename: String
    prefix: String
    suffix: String
    email: String
    dob: String @deprecated(reason: "Use 'date_of_birth' instead.")
    date_of_birth: String
    taxvat: String
    gender: Int
    is_subscribed: Boolean
    created_at: String
    default_billing: String
    default_shipping: String
    addresses: [CustomerAddress]
    addressesV2(currentPage: Int = 1, pageSize: Int = 5): CustomerAddresses
    confirmation_status: ConfirmationStatusEnum!
    group_id: Int @deprecated(reason: "Use 'group' instead.")
    group: CustomerGroup
    orders(filter: CustomerOrdersFilterInput, currentPage: Int = 1, pageSize: Int = 20, sort: CustomerOrderSortInput): CustomerOrders
}

type CustomerAddress {
    id: Int @deprecated(reason: "Use 'uid' instead.")
    uid: ID!
    customer_id: Int @deprecated(reason: "Use 'uid' instead.")
    firstname: String
    lastname: String
    middlename: String
    prefix: String
    suffix: String
    company: String
    street: [String]
    city: String
    region: CustomerAddressRegion
    region_id: Int
    postcode: String
    country_code: CountryCodeEnum
    country_id: String @deprecated(reason: "Use 'country_code' instead.")
    telephone: String
    fax: String
    vat_id: String
    default_shipping: Boolean
    default_billing: Boolean
}

type CustomerAddresses {
    """List of customer addresses."""
    items: [CustomerAddress]
    """Pagination metadata."""
    page_info: SearchResultPageInfo
    """Total number of addresses."""
    total_count: Int
}

type SearchResultPageInfo {
    current_page: Int
    page_size: Int
    total_pages: Int
}

type CustomerAddressRegion {
    region_code: String
    region: String
    region_id: Int
}

type CustomerToken {
    token: String
}

type CustomerOutput {
    customer: Customer!
}

type RevokeCustomerTokenOutput {
    result: Boolean!
}

type IsEmailAvailableOutput {
    is_email_available: Boolean
}

type CustomerGroup {
    uid: ID!
    name: String!
}

# ─── Input Types ─────────────────────────────────────────────────────────────

input CustomerCreateInput {
    firstname: String!
    lastname: String!
    email: String!
    password: String!
    prefix: String
    middlename: String
    suffix: String
    date_of_birth: String
    taxvat: String
    gender: Int
    is_subscribed: Boolean
}

input CustomerUpdateInput {
    firstname: String
    lastname: String
    middlename: String
    prefix: String
    suffix: String
    date_of_birth: String
    taxvat: String
    gender: Int
    is_subscribed: Boolean
}

"""Deprecated: Use CustomerCreateInput/CustomerUpdateInput instead."""
input CustomerInput {
    prefix: String
    firstname: String
    middlename: String
    lastname: String
    suffix: String
    email: String
    dob: String @deprecated(reason: "Use 'date_of_birth' instead.")
    date_of_birth: String
    taxvat: String
    gender: Int
    password: String
    is_subscribed: Boolean
}

input CustomerAddressInput {
    firstname: String
    lastname: String
    middlename: String
    prefix: String
    suffix: String
    company: String
    street: [String]
    city: String
    region: CustomerAddressRegionInput
    postcode: String
    country_code: CountryCodeEnum
    country_id: CountryCodeEnum @deprecated(reason: "Use 'country_code' instead.")
    telephone: String
    fax: String
    vat_id: String
    default_shipping: Boolean
    default_billing: Boolean
}

input CustomerAddressRegionInput {
    region_code: String
    region: String
    region_id: Int
}

input ConfirmEmailInput {
    email: String!
    confirmation_key: String!
}

# ─── Enums ───────────────────────────────────────────────────────────────────

enum ConfirmationStatusEnum {
    ACCOUNT_CONFIRMED
    ACCOUNT_CONFIRMATION_NOT_REQUIRED
}

enum CountryCodeEnum {
    AF AX AL DZ AS AD AO AI AQ AG AR AM AW AU AT AZ BS BH BD BB BY BE BZ BJ
    BM BT BO BA BW BV BR IO VG BN BG BF BI KH CM CA CV KY CF TD CL CN CX CC
    CO KM CG CD CK CR CI HR CU CY CZ DK DJ DM DO EC EG SV GQ ER EE ET FK FO
    FJ FI FR GF PF TF GA GM GE DE GH GI GR GL GD GP GU GT GG GN GW GY HT HM
    HN HK HU IS IN ID IR IQ IE IM IL IT JM JP JE JO KZ KE KI KW KG LA LV LB
    LS LR LY LI LT LU MO MK MG MW MY MV ML MT MH MQ MR MU YT MX FM MD MC MN
    ME MS MA MZ MM NA NR NP NL AN NC NZ NI NE NG NU NF KP MP NO OM PK PW PS
    PA PG PY PE PH PN PL PT QA RE RO RU RW WS SM ST SA SN RS SC SL SG SK SI
    SB SO ZA GS KR ES LK BL SH KN LC MF PM VC SS SD SR SJ SZ SE CH SY TW TJ
    TZ TH TL TG TK TO TT TN TR TM TC TV UG UA AE GB US UM VI UY UZ VU VA VE
    VN WF EH YE ZM ZW
}

enum CurrencyEnum {
    USD EUR GBP CAD AUD JPY CNY CHF SEK NOK DKK NZD MXN SGD HKD
    INR BRL ZAR RUB KRW TRY PLN CZK HUF RON BGN HRK ILS PHP THB
    MYR IDR AED SAR QAR KWD BHD OMR JOD LBP EGP MAD TND DZD LYD
    NGN GHS KES TZS UGX ETB UAH GEL AMD AZN KZT UZS BDT PKR LKR
    NPR MMK KHR LAK VND MOP TWD
}

enum SortEnum {
    ASC
    DESC
}

# ─── Order Filter & Sort Inputs ───────────────────────────────────────────────

input FilterStringTypeInput {
    eq: String
    match: String
    in: [String]
}

input FilterRangeTypeInput {
    from: String
    to: String
}

input FilterEqualTypeInput {
    eq: String
    in: [String]
}

input CustomerOrdersFilterInput {
    number: FilterStringTypeInput
    order_date: FilterRangeTypeInput
    status: FilterEqualTypeInput
    grand_total: FilterRangeTypeInput
}

input CustomerOrderSortInput {
    order_date: SortEnum
    number: SortEnum
    grand_total: SortEnum
}

# ─── Order Output Types ───────────────────────────────────────────────────────

type Money {
    value: Float
    currency: CurrencyEnum
}

type CustomerOrders {
    """List of customer orders."""
    items: [CustomerOrder]!
    """Pagination metadata."""
    page_info: SearchResultPageInfo
    """Total number of orders matching the filter."""
    total_count: Int
}

type CustomerOrder {
    id: ID!
    """The order increment ID (same as number)."""
    order_number: String!
    """The order increment ID."""
    number: String!
    """The date the order was placed."""
    order_date: String!
    """The current status of the order."""
    status: String!
    """The carrier for the order."""
    carrier: String
    """The shipping method."""
    shipping_method: String
    """The shipping address."""
    shipping_address: OrderAddress
    """The billing address."""
    billing_address: OrderAddress
    """Payment methods used for the order."""
    payment_methods: [OrderPaymentMethod]!
    """A list of order line items."""
    items: [OrderItemInterface]!
    """The total amounts of the order."""
    total: OrderTotal
    """A list of invoices for the order."""
    invoices: [Invoice]!
    """A list of shipments for the order."""
    shipments: [OrderShipment]
    """A list of credit memos for the order."""
    credit_memos: [CreditMemo]
    """A list of customer-visible comments on the order."""
    comments: [SalesCommentItem]
}

type OrderTotal {
    grand_total: Money!
    subtotal: Money!
    total_tax: Money!
    total_shipping: Money!
    taxes: [TaxItem]
    discounts: [Discount]
    shipping_handling: ShippingHandling
}

type TaxItem {
    amount: Money!
    title: String!
    rate: Float!
}

type Discount {
    amount: Money!
    label: String!
}

type ShippingHandling {
    amount_including_tax: Money
    amount_excluding_tax: Money
    total_amount: Money!
    taxes: [TaxItem]
    discounts: [ShippingDiscount]
}

type ShippingDiscount {
    amount: Money!
}

type KeyValue {
    name: String
    value: String
}

type OrderAddress {
    firstname: String!
    lastname: String!
    middlename: String
    prefix: String
    suffix: String
    company: String
    street: [String]!
    city: String!
    region: String
    region_id: Int
    postcode: String
    country_code: CountryCodeEnum
    telephone: String
    fax: String
    vat_id: String
}

type OrderPaymentMethod {
    name: String!
    type: String!
    additional_data: [KeyValue]
}

interface OrderItemInterface {
    id: ID!
    product_name: String
    product_sku: String!
    product_url_key: String
    product_type: String
    product_sale_price: Money!
    quantity_ordered: Float
    quantity_shipped: Float
    quantity_invoiced: Float
    quantity_refunded: Float
    quantity_canceled: Float
    status: String
    discounts: [Discount]
    entered_options: [OrderItemOption]
    selected_options: [OrderItemOption]
}

type OrderItem implements OrderItemInterface {
    id: ID!
    product_name: String
    product_sku: String!
    product_url_key: String
    product_type: String
    product_sale_price: Money!
    quantity_ordered: Float
    quantity_shipped: Float
    quantity_invoiced: Float
    quantity_refunded: Float
    quantity_canceled: Float
    status: String
    discounts: [Discount]
    entered_options: [OrderItemOption]
    selected_options: [OrderItemOption]
}

type OrderItemOption {
    id: String!
    label: String!
    value: String!
}

type SalesCommentItem {
    message: String!
    timestamp: String!
}

# ─── Invoice Types ────────────────────────────────────────────────────────────

type Invoice {
    id: ID!
    number: String!
    total: InvoiceTotal
    items: [InvoiceItemInterface]
    comments: [SalesCommentItem]
}

type InvoiceTotal {
    grand_total: Money!
    subtotal: Money!
    total_tax: Money!
    total_shipping: Money!
    taxes: [TaxItem]
    discounts: [Discount]
    shipping_handling: ShippingHandling
}

interface InvoiceItemInterface {
    id: ID!
    product_name: String
    product_sku: String!
    product_sale_price: Money!
    quantity_invoiced: Float!
    discounts: [Discount]
    order_item: OrderItemInterface
}

type InvoiceItem implements InvoiceItemInterface {
    id: ID!
    product_name: String
    product_sku: String!
    product_sale_price: Money!
    quantity_invoiced: Float!
    discounts: [Discount]
    order_item: OrderItemInterface
}

# ─── Shipment Types ───────────────────────────────────────────────────────────

type OrderShipment {
    id: ID!
    number: String!
    tracking: [ShipmentTracking]
    items: [ShipmentItemInterface]
    comments: [SalesCommentItem]
}

type ShipmentTracking {
    title: String!
    carrier: String!
    number: String
}

interface ShipmentItemInterface {
    id: ID!
    product_name: String
    product_sku: String!
    quantity_shipped: Float!
    order_item: OrderItemInterface
}

type ShipmentItem implements ShipmentItemInterface {
    id: ID!
    product_name: String
    product_sku: String!
    quantity_shipped: Float!
    order_item: OrderItemInterface
}

# ─── Credit Memo Types ────────────────────────────────────────────────────────

type CreditMemo {
    id: ID!
    number: String!
    total: CreditMemoTotal
    items: [CreditMemoItemInterface]
    comments: [SalesCommentItem]
}

type CreditMemoTotal {
    grand_total: Money!
    subtotal: Money!
    total_tax: Money!
    total_shipping: Money!
    taxes: [TaxItem]
    discounts: [Discount]
    shipping_handling: ShippingHandling
}

interface CreditMemoItemInterface {
    id: ID!
    product_name: String
    product_sku: String!
    product_sale_price: Money!
    quantity_refunded: Float!
    discounts: [Discount]
    order_item: OrderItemInterface
}

type CreditMemoItem implements CreditMemoItemInterface {
    id: ID!
    product_name: String
    product_sku: String!
    product_sale_price: Money!
    quantity_refunded: Float!
    discounts: [Discount]
    order_item: OrderItemInterface
}
